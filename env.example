# ===================================================================
# AEVUM ENVIRONMENT VARIABLES
# ===================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it contains secrets.
# ===================================================================

# --- App Identity (from Kimi portal) ---
APP_ID=your-app-id-here
APP_SECRET=your-app-secret-here
VITE_APP_ID=your-app-id-here
VITE_KIMI_AUTH_URL=https://auth.kimi.com
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com

# --- Database (TiDB Cloud or MySQL) ---
# Format: mysql://user:password@host:port/database?ssl={"rejectUnauthorized":true}
DATABASE_URL=your-database-url-here

# --- OpenAI (for real AI responses and image generation) ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Admin ---
# Your Kimi union ID — you are automatically admin
OWNER_UNION_ID=your-union-id-here
